<DevelopmentPlan VERSION="1.0.0">
  <overview>
    План разработки для сервиса статистики Meshtastic.
    Фаза 1: Создание базовой инфраструктуры для сбора и анализа данных.
    Фаза 2: Интеграция с внешними сервисами, генерация отчетов и планирование.
  </overview>

  <Phases>
    <Phase-1 NAME="Core Data and Statistics">
      <description>Реализация основных модулей для сбора, хранения и обработки данных Meshtastic.</description>
      <step-1 MODULE="M-CONFIG" ACTION="Создать модуль для управления конфигурацией." />
      <step-2 MODULE="M-DATASTORE" ACTION="Создать модуль для хранения данных в памяти." />
      <step-3 MODULE="M-COLLECTOR" ACTION="Реализовать сборщик пакетов Meshtastic." />
      <step-4 MODULE="M-STATS" ACTION="Реализовать калькулятор статистики." />
    </Phase-1>
    <Phase-2 NAME="Reporting and Scheduling" status="done">
      <description>Реализация модулей для получения данных о погоде, создания и отправки отчетов по расписанию.</description>
      <step-1 MODULE="M-WEATHER" ACTION="Создать сервис для получения данных о погоде." />
      <step-2 MODULE="M-MESHTASTIC" ACTION="Создать интерфейс для взаимодействия с Meshtastic." />
      <step-3 MODULE="M-REPORTER" ACTION="Реализовать генератор отчетов." />
      <step-4 MODULE="M-SCHEDULER" ACTION="Создать главный модуль-планировщик." />
    </Phase-2>
  </Phases>

  <DataFlows>
    <DF-DAILY-REPORT NAME="Daily Statistics Report">
      <description>Полный поток от сбора данных до отправки ежедневного отчета.</description>
      <steps>
        <step-1>PacketCollector собирает данные в DataStore.</step-1>
        <step-2>Scheduler запрашивает данные у StatsCalculator и WeatherService.</step-2>
        <step-3>ReportGenerator формирует отчет.</step-3>
        <step-4>MeshtasticInterface отправляет отчет.</step-4>
      </steps>
      <verification-ref>V-DF-DAILY-REPORT</verification-ref>
    </DF-DAILY-REPORT>
  </DataFlows>

  <Modules>
    <M-CONFIG NAME="ConfigManager" TYPE="UTILITY">
      <purpose>Управляет конфигурацией приложения.</purpose>
      <target-path>src/config.py</target-path>
      <verification-ref>V-M-CONFIG</verification-ref>
    </M-CONFIG>
    <M-DATASTORE NAME="DataStore" TYPE="DATA_LAYER">
      <purpose>Хранит пакеты Meshtastic в SQLite базе данных с политикой хранения 6 месяцев.</purpose>
      <target-path>src/datastore.py</target-path>
      <verification-ref>V-M-DATASTORE</verification-ref>
      <features>
        <feature>Постоянное хранение данных в SQLite</feature>
        <feature>Автоматическая очистка данных старше 6 месяцев</feature>
        <feature>Индексация по времени получения и идентификаторам</feature>
        <feature>Сериализация пакетов в JSON формате</feature>
      </features>
    </M-DATASTORE>
    <M-COLLECTOR NAME="PacketCollector" TYPE="CORE_LOGIC">
      <purpose>Прослушивает и сохраняет пакеты Meshtastic.</purpose>
      <target-path>src/collector.py</target-path>
      <verification-ref>V-M-COLLECTOR</verification-ref>
    </M-COLLECTOR>
    <M-STATS NAME="StatsCalculator" TYPE="CORE_LOGIC">
      <purpose>Вычисляет статистику сети.</purpose>
      <target-path>src/stats.py</target-path>
      <verification-ref>V-M-STATS</verification-ref>
    </M-STATS>
    <M-WEATHER NAME="WeatherService" TYPE="INTEGRATION">
      <purpose>Получает данные о погоде.</purpose>
      <target-path>src/weather.py</target-path>
      <verification-ref>V-M-WEATHER</verification-ref>
    </M-WEATHER>
    <M-REPORTER NAME="ReportGenerator" TYPE="CORE_LOGIC">
      <purpose>Формирует итоговый отчет.</purpose>
      <target-path>src/reporter.py</target-path>
      <verification-ref>V-M-REPORTER</verification-ref>
    </M-REPORTER>
    <M-MESHTASTIC NAME="MeshtasticInterface" TYPE="INTEGRATION">
      <purpose>Управляет взаимодействием с Meshtastic.</purpose>
      <target-path>src/meshtastic_interface.py</target-path>
      <verification-ref>V-M-MESHTASTIC</verification-ref>
    </M-MESHTASTIC>
    <M-SCHEDULER NAME="Scheduler" TYPE="ENTRY_POINT">
      <purpose>Координирует генерацию и отправку отчета.</purpose>
      <target-path>src/main.py</target-path>
      <verification-ref>V-M-SCHEDULER</verification-ref>
    </M-SCHEDULER>
  </Modules>
</DevelopmentPlan>
